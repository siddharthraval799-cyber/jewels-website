{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "server/server.cjs": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.cjs"
    },
    {
      "source": "/admin(.*)",
      "destination": "/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}