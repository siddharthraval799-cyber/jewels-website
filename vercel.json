{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.cjs": {
      "excludeFiles": "{public/**,dist/**,node_modules/**/.git/**}"
    }
  }
}
